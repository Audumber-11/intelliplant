# IntelliPlant Configuration
# Copy this to .env and fill in your values

# --- Database ---
DATABASE_URL=sqlite:///./intelliplant.db
# For production:
# DATABASE_URL=postgresql://user:pass@host:5432/intelliplant

# --- Redis (optional, for caching) ---
REDIS_URL=redis://localhost:6379/0

# --- LLM / AI ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# If no key provided, the system runs in mock/fallback mode

# --- ChromaDB (Vector Store) ---
CHROMA_PERSIST_DIR=./chroma_db

# --- Server ---
HOST=0.0.0.0
PORT=8000
